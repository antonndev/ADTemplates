{
  "id": "rust",
  "name": "Rust",
  "description": "Rust dedicated server template using didstopia/rust-server. The image installs and updates the server on startup, stores all data under /steamcmd/rust and supports WebRCON plus Rust+.",
  "defaultPort": 28015,
  "templateImage": "https://cdn.jsdelivr.net/gh/antonndev/ADCDn/rust-logo.avif",
  "docker": {
    "image": "didstopia/rust-server",
    "tag": "full",
    "ports": [
      28015,
      28016,
      28082
    ],
    "portProtocols": {
      "28015": [
        "udp"
      ],
      "28016": [
        "tcp",
        "udp"
      ],
      "28082": [
        "tcp",
        "udp"
      ]
    },
    "volumes": [
      "{BOT_DIR}:/steamcmd/rust"
    ],
    "workdir": "/steamcmd/rust",
    "env": {
      "RUST_SERVER_STARTUP_ARGUMENTS": "-batchmode -load -nographics +server.secure 1",
      "RUST_SERVER_IDENTITY": "adpanel",
      "RUST_SERVER_PORT": "28015",
      "RUST_SERVER_QUERYPORT": "28016",
      "RUST_SERVER_SEED": "12345",
      "RUST_SERVER_WORLDSIZE": "3500",
      "RUST_SERVER_NAME": "ADPanel Rust Server",
      "RUST_SERVER_DESCRIPTION": "Rust server hosted with ADPanel",
      "RUST_SERVER_MAXPLAYERS": "100",
      "RUST_RCON_WEB": "1",
      "RUST_RCON_PORT": "28016",
      "RUST_RCON_PASSWORD": "change-me",
      "RUST_APP_PORT": "28082",
      "RUST_UPDATE_CHECKING": "1",
      "RUST_UPDATE_BRANCH": "public",
      "RUST_OXIDE_ENABLED": "0",
      "TZ": "Etc/UTC"
    },
    "command": "",
    "adpanelStartup": "",
    "install": {
      "image": "ghcr.io/pterodactyl/installers:debian",
      "script": "#!/bin/sh\nset -eu\nmkdir -p /mnt/server/server/adpanel /mnt/server/oxide /mnt/server/cfg\nchmod -R 777 /mnt/server",
      "mountPath": "/mnt/server",
      "runtimePath": "/steamcmd/rust",
      "minimumStorageMb": 12000
    },
    "restart": "unless-stopped",
    "console": {
      "type": "stdin"
    }
  },
  "documentation": [
    "https://hub.docker.com/r/didstopia/rust-server",
    "https://wiki.facepunch.com/rust/rust-companion-server"
  ],
  "requirements": {
    "minimumRamMb": 4096,
    "recommendedRamMb": 8192,
    "minimumStorageMb": 12000
  }
}
